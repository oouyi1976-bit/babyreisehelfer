---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import '../styles/global.css';

type JsonLd = Record<string, unknown> | Record<string, unknown>[];

const {
  title = 'BabyReiseHelfer',
  description = 'BabyReiseHelfer sammelt Packlisten, Produktideen und Ratgeber für entspannte Reisen mit Baby.',
  ogType = 'website',
  canonical,
  jsonLd
} = Astro.props as {
  title?: string;
  description?: string;
  ogType?: string;
  canonical?: string;
  jsonLd?: JsonLd;
};

const site = Astro.site ?? new URL('https://babyreisehelfer.pages.dev');
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site);
const pageTitle = title.includes('BabyReiseHelfer') ? title : `${title} | BabyReiseHelfer`;
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'BabyReiseHelfer',
  url: site.toString(),
  inLanguage: 'de-DE',
  description
};
const jsonLdItems = jsonLd
  ? [websiteSchema, ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])]
  : [websiteSchema];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="yPpe7RqFmJlFWGW8pmTMccb6P9_85pKfoSRyazRjG6g" />
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <meta property="og:site_name" content="BabyReiseHelfer" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={new URL('/og-image.svg', site).href} />
    <meta name="twitter:card" content="summary_large_image" />

    {jsonLdItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <Header />
    <div class="container disclosure-container">
      <AffiliateDisclosure compact />
    </div>
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import { initAffiliateTracking } from '../lib/affiliateTracking';
      initAffiliateTracking();
    </script>
  </body>
</html>
