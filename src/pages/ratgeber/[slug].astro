---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductComparisonTable from '../../components/ProductComparisonTable.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import ProsConsBox from '../../components/ProsConsBox.astro';
import CTABox from '../../components/CTABox.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import { getProductsByIds } from '../../data/products';
import { getTravelProductsByIds } from '../../data/travelProducts';
import { getCategoryBySlug } from '../../data/categories';
import { getTravelPageBySlug } from '../../data/travelPages';

export async function getStaticPaths() {
  const entries = await getCollection('ratgeber');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const category = getCategoryBySlug(entry.data.category);
const travelPage = getTravelPageBySlug(entry.data.category);
const breadcrumbHref = category ? `/${category.slug}/` : travelPage ? `/${travelPage.slug}/` : '/';
const breadcrumbLabel = category?.title ?? travelPage?.eyebrow ?? 'Ratgeber';
const featuredProducts = getProductsByIds(entry.data.featuredProductIds);
const featuredTravelProducts = getTravelProductsByIds(entry.data.featuredProductIds);
const allArticles = await getCollection('ratgeber');
const relatedArticles = allArticles
  .filter((article) => article.id !== entry.id && article.data.category === entry.data.category)
  .slice(0, 3);
const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric'
}).format(entry.data.date);
const articleUrl = new URL(`/ratgeber/${entry.id}/`, Astro.site).href;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  inLanguage: 'de-DE',
  mainEntityOfPage: articleUrl,
  author: {
    '@type': 'Organization',
    name: 'BabyReiseHelfer'
  },
  publisher: {
    '@type': 'Organization',
    name: 'BabyReiseHelfer'
  }
};
---

<Layout title={entry.data.title} description={entry.data.description} ogType="article" jsonLd={articleSchema}>
  <article class="article-layout">
    <header class="article-hero">
      <div class="container article-hero__inner">
        <a class="breadcrumb" href={breadcrumbHref}>{breadcrumbLabel}</a>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.excerpt}</p>
        <div class="article-meta">
          <span>{formattedDate}</span>
          <span>{entry.data.readingTime} Minuten Lesezeit</span>
        </div>
      </div>
    </header>

    <div class="container article-layout__grid">
      <div class="article-content">
        <Content />

        {(featuredProducts.length > 0 || featuredTravelProducts.length > 0) && (
          <>
            <AffiliateDisclosure compact />
            <section id="affiliate-link-eintragen" class="article-product-section">
              <h2>Passende Produktideen zum Ratgeber</h2>
              <p>
                Die folgenden Karten zeigen neutrale Produktideen und digitale Ratgeber. Affiliate-Links sind sichtbar gekennzeichnet; Preise, Sternebewertungen und erfundene Testsieger werden nicht angezeigt.
              </p>
              {featuredProducts.length > 0 && (
                <div class="product-grid product-grid--article">
                  {featuredProducts.map((product) => <ProductCard product={product} compact />)}
                </div>
              )}
              {featuredTravelProducts.length > 0 && <ProductGrid products={featuredTravelProducts} compact />}
            </section>
          </>
        )}

        {featuredProducts.length > 2 && (
          <section class="article-product-section">
            <h2>Kurzer Vergleich</h2>
            <ProductComparisonTable products={featuredProducts} />
          </section>
        )}

        {featuredTravelProducts.length > 2 && (
          <section class="article-product-section">
            <h2>Kurzer Reiseprodukt-Vergleich</h2>
            <ComparisonTable products={featuredTravelProducts} />
          </section>
        )}

        <ProsConsBox
          title="So nutzt du Produktideen sinnvoll"
          pros={[
            'Wähle nach Reisesituation statt nach Trend',
            'Teste Befestigung, Größe und Bedienung vor Abreise',
            'Packe nur ein, was den Alltag wirklich erleichtert'
          ]}
          cons={[
            'Sicherheits- und Altershinweise immer beim Hersteller prüfen',
            'Medizinische Fragen mit Kinderarzt oder Apotheke abstimmen',
            'Nicht jeder Helfer passt zu jedem Baby oder Reiseziel'
          ]}
        />
      </div>

      <aside class="article-sidebar">
        <div class="sidebar-box">
          <h2>In diesem Artikel</h2>
          <p>{entry.data.description}</p>
          {category && <a class="text-link" href={`/${category.slug}/`}>Mehr zu {category.title}</a>}
          {travelPage && <a class="text-link" href={`/${travelPage.slug}/`}>Mehr zu {travelPage.eyebrow}</a>}
        </div>
      </aside>
    </div>
  </article>

  {relatedArticles.length > 0 && (
    <section class="section section--soft">
      <div class="container">
        <div class="section__header">
          <p class="eyebrow">Weiterlesen</p>
          <h2>Mehr Ratgeber in dieser Rubrik</h2>
        </div>
        <div class="article-grid">
          {relatedArticles.map((article) => <ArticleCard article={article} />)}
        </div>
      </div>
    </section>
  )}

  <div class="container section">
    <CTABox
      title="Noch einmal durch die Packliste gehen"
      text="Vor dem Packen lohnt sich ein letzter Blick auf Flug, Hotel, Strand und Kinderwagen."
      href="/packlisten/"
      buttonText="Packlisten ansehen"
    />
  </div>
</Layout>
