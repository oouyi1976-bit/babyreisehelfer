            <li><a href="/strandurlaub-mit-baby-packliste/">Strandurlaub mit Baby</a></li>
          </ul>
        </section>

        <section class="guide-sidebar__box guide-sidebar__box--products">
          <p class="eyebrow">Auswahl</p>
          <h2>Unsere Empfehlungen</h2>
          {sidebarProducts.map((product) => {
            const linked = isAmazonAffiliateReady(product);
            return (
              <article class="guide-sidebar-product">
                {linked ? (
                  <a href={product.affiliateUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-affiliate-link data-product-id={product.id} data-product-title={product.name} aria-label={`${product.name} ansehen`}>
                    <img src={product.image} alt={product.imageAlt} width="180" height="135" loading="lazy" decoding="async" />
                  </a>
                ) : (
                  <img src={product.image} alt={product.imageAlt} width="180" height="135" loading="lazy" decoding="async" />
                )}
                <div>
                  <h3>{linked ? <a href={product.affiliateUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-affiliate-link data-product-id={product.id} data-product-title={product.name}>{product.name}</a> : product.name}</h3>
                  {linked ? <AffiliateButton href={product.affiliateUrl} label="Produkt ansehen" trackingId={product.id} trackingTitle={product.name} /> : <a class="text-link" href="/reiseprodukte/">Produktübersicht</a>}
                </div>
              </article>
            );
          })}
        </section>

        <section class="guide-sidebar__box guide-sidebar__cta">
          <p class="eyebrow">Kostenlos</p>
          <h2>Kostenlose Reise-Checkliste</h2>
          <p>Starte mit einer klaren Liste für Flug, Hotel, Strand und unterwegs.</p>
          <a class="button" href="/packlisten/">Packlisten ansehen</a>
        </section>
      </aside>
    </div>
  </article>
</Layout>
