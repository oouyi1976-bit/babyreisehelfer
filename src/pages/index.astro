---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ProductCard from '../components/ProductCard.astro';
import HeroVisual from '../components/HeroVisual.astro';
import TrustBar from '../components/TrustBar.astro';
import TipsCompareSection from '../components/TipsCompareSection.astro';
import { categories } from '../data/categories';
import { babysleepProductIds, getProductsByIds } from '../data/products';

const articles = (await getCollection('ratgeber'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const featuredCategories = categories;
const babysleepProducts = getProductsByIds(babysleepProductIds);
const travelHomeLinks = [
  {
    title: 'Reisen mit Kind',
    href: '/reisen-mit-kind/',
    description: 'Planung, Handgepäck, Snacks und kleine Routinen für entspanntere Reisetage.'
  },
  {
    title: 'Flugreise mit Kind',
    href: '/flugreise-mit-kind/',
    description: 'Checkliste für Boarding, Handgepäck, Beschäftigung und Wartezeiten.'
  },
  {
    title: 'Familienurlaub',
    href: '/familienurlaub/',
    description: 'Unterkunft, Budget, Packliste und Alltagstauglichkeit im Familienurlaub.'
  },
  {
    title: 'Reiseprodukte',
    href: '/reiseprodukte/',
    description: '50 Produktideen für Reisebett, Buggy, Sonnenschutz, Flugzeug und Strand.'
  },
  {
    title: 'Madeira mit Bus',
    href: '/madeira-mit-bus/',
    description: 'Tipps für Madeira ohne Mietwagen, Busplanung und passende Packideen.'
  }
];
const topProducts = getProductsByIds([
  'kinderwagen-sonnenschutz',
  'faltbare-wickelunterlage',
  'baby-gehoerschutz',
  'nachtlicht-hotel',
  'baby-strandmuschel',
  'reisebett',
  'packing-cubes-baby-kleidung',
  'reisedokumententasche-familie'
]);
---

<Layout
  title="Baby-Reiseprodukte, Packlisten und Ratgeber"
  description="BabyReiseHelfer bietet praktische Packlisten, neutrale Produktideen und Ratgeber für Urlaub, Flugzeug, Hotel, Strand und Kinderwagen mit Baby."
>
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__content">
        <p class="eyebrow">BabyReiseHelfer</p>
        <h1>Baby-Reiseprodukte, die im Urlaub <span>wirklich</span> helfen</h1>
        <p class="hero__subtitle">
          Praktische Packlisten, clevere Produktideen und ehrliche Ratgeber für entspannte Reisen mit Baby – ob im Flugzeug, im Hotel, am Strand oder mit dem Kinderwagen unterwegs.
        </p>
        <div class="hero__actions">
          <a class="button" href="/packlisten/">Packlisten entdecken</a>
          <a class="button button--secondary" href="#ratgeber">Ratgeber lesen</a>
        </div>
      </div>

      <HeroVisual />
    </div>
  </section>

  <TrustBar />

  <section class="section travel-home" id="urlaub-reisen-mit-kind">
    <div class="container">
      <div class="section__header section__header--split">
        <div>
          <p class="eyebrow">Urlaub & Reisen mit Kind</p>
          <h2>Neue Einstiege für Familienurlaub, Flugreise und Reiseprodukte</h2>
        </div>
        <p>
          Der neue Reisebereich verbindet SEO-Ratgeber, Amazon-Produktideen und passend eingeordnete digitale Reise-Empfehlungen.
          <a class="text-link" href="/urlaub/">Urlaub-Bereich öffnen</a>
        </p>
      </div>
      <div class="travel-home-grid">
        {travelHomeLinks.map((item) => (
          <a class="travel-home-card" href={item.href}>
            <span>{item.title}</span>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section sleep-home" id="babyschlaf">
    <div class="container">
      <div class="section__header section__header--split">
        <div>
          <p class="eyebrow">Babyschlaf & ruhige Nächte</p>
          <h2>Sanfte Ratgeber für Schlaf, Tagesschlaf und neue Routinen</h2>
        </div>
        <p>
          Keine Schlafgarantie und kein Druck. Diese digitalen Ratgeber können Eltern Orientierung geben, wenn Nächte, Reisen oder Tagesabläufe gerade viel Kraft brauchen.
          <a class="text-link" href="/babyschlaf/">Babyschlaf-Bereich öffnen</a>
        </p>
      </div>
      <div class="product-grid product-grid--featured">
        {babysleepProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section" id="kategorien">
    <div class="container">
      <div class="section__header">
        <p class="eyebrow">Schnell einsteigen</p>
        <h2>Kategorien für jede Reisephase</h2>
      </div>
      <div class="category-grid">
        {featuredCategories.map((category) => <CategoryCard category={category} />)}
      </div>
    </div>
  </section>

  <section class="section section--soft" id="produkte">
    <div class="container">
      <div class="section__header section__header--split">
        <div>
          <p class="eyebrow">Empfohlene Produkte</p>
          <h2>Hochwertig sortierte Produktideen ohne Shop-Gefühl</h2>
        </div>
        <p>
          Keine Preise, keine Amazon-Sterne und keine erfundenen Testsieger. Die Karten zeigen neutrale Produktideen mit Kaufkriterien.
          <a class="text-link" href="/produkte/">Alle Produkte ansehen</a>
        </p>
      </div>
      <div class="product-grid">
        {topProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section" id="ratgeber">
    <div class="container">
      <div class="section__header section__header--split">
        <div>
          <p class="eyebrow">Ratgeber & Inspiration</p>
          <h2>Planen, packen und entspannter losfahren</h2>
        </div>
        <a class="text-link" href="/packlisten/">Alle Packlisten ansehen</a>
      </div>
      <div class="article-grid">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <TipsCompareSection />
</Layout>
