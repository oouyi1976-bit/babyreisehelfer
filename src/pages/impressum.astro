---
import Layout from '../layouts/Layout.astro';
import { isLegalProfileComplete, legalProfile } from '../data/legal';

const legalComplete = isLegalProfileComplete();
const hasPartialLegalInfo = Boolean(legalProfile.operatorName || legalProfile.ownerName);
---

<Layout
  title="Impressum"
  description="Anbieterkennzeichnung und Kontaktangaben von BabyReiseHelfer."
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <p class="eyebrow">Rechtliches</p>
      <h1>Impressum</h1>
      <p>Anbieterkennzeichnung und Kontaktinformationen für BabyReiseHelfer.</p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <h2>Anbieterkennzeichnung</h2>
      {(legalComplete || hasPartialLegalInfo) && (
        <dl class="legal-list">
          {legalProfile.operatorName && (
            <div>
              <dt>Firma / Betreiber</dt>
              <dd>{legalProfile.operatorName}</dd>
            </div>
          )}
          {legalProfile.ownerName && (
            <div>
              <dt>Inhaber</dt>
              <dd>{legalProfile.ownerName}</dd>
            </div>
          )}
          {legalProfile.addressLines.length > 0 && (
            <div>
              <dt>Ladungsfähige Anschrift</dt>
              <dd>
                {legalProfile.addressLines.map((line) => (
                  <>{line}<br /></>
                ))}
              </dd>
            </div>
          )}
          {legalProfile.email && (
            <div>
              <dt>E-Mail</dt>
              <dd><a class="text-link" href={`mailto:${legalProfile.email}`}>{legalProfile.email}</a></dd>
            </div>
          )}
        </dl>
      )}

      {!legalComplete && (
        <aside class="notice-box">
          <h2>Hinweis zur Anbieterkennzeichnung</h2>
          <p>
            Es werden nur echte, zur Veröffentlichung freigegebene Kontaktdaten angezeigt. Eine ladungsfähige Anschrift und eine Kontakt-E-Mail sollten vor dauerhaftem kommerziellem Betrieb in <code>src/data/legal.ts</code> ergänzt und fachkundig geprüft werden.
          </p>
        </aside>
      )}

      {legalProfile.email && (
        <>
          <h2>Kontakt</h2>
          <p>E-Mail: <a class="text-link" href={`mailto:${legalProfile.email}`}>{legalProfile.email}</a></p>
        </>
      )}

      <h2>Hinweis</h2>
      <p>
        Impressum, Datenschutz, Affiliate-Kennzeichnung und steuerliche Angaben sollten vor dauerhaftem kommerziellem Betrieb fachkundig geprüft werden.
      </p>
    </div>
  </section>
</Layout>
