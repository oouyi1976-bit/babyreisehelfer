---
import AffiliateButton from './AffiliateButton.astro';
import { isAmazonAffiliateReady } from '../data/travelProducts';
import type { AmazonArticleCardProduct } from '../data/amazonArticleProducts';

const { products, adImage } = Astro.props as { products: AmazonArticleCardProduct[]; adImage: string };
---

<div class="article-sidebar-stack">
  <section class="article-sidebar-ad">
    <div class="article-sidebar-ad__content">
      <span>Anzeige</span>
      <h2>Praktische Reisehelfer, die unterwegs wirklich Platz sparen</h2>
      <p>Vom übersichtlichen Wickelrucksack bis zum kompakten Reisebett: Entdecke praktische Produkte für Flugzeug, Hotel, Autofahrt und Strand.</p>
      <a class="button" href="/reiseprodukte/">Reisehelfer entdecken</a>
    </div>
    <img src={adImage} alt="Geöffneter Wickelrucksack mit Packwürfeln und Reise-Basics im Hotelzimmer" width="960" height="720" loading="lazy" decoding="async" />
  </section>

  <section class="article-sidebar-products">
    <h2>Unsere Top-Produktempfehlungen</h2>
    {products.map((product) => {
      const hasReadyLink = isAmazonAffiliateReady(product);
      const productImage = product.amazonImageUrl;
      const linkAttributes = {
        target: '_blank',
        rel: 'nofollow sponsored noopener noreferrer',
        'data-affiliate-link': true,
        'data-product-id': product.id,
        'data-product-title': product.name
      };
      return (
        <article class:list={['article-sidebar-product', { 'article-sidebar-product--without-amazon-image': !productImage }]}>
          {productImage && (hasReadyLink ? (
            <a href={product.affiliateUrl} aria-label={`${product.name} ansehen`} {...linkAttributes}>
              <img src={productImage} alt={product.name} width="180" height="135" loading="lazy" decoding="async" />
            </a>
          ) : (
            <img src={productImage} alt={product.name} width="180" height="135" loading="lazy" decoding="async" />
          ))}
          <div>
            <h3>{hasReadyLink ? <a href={product.affiliateUrl} {...linkAttributes}>{product.name}</a> : product.name}</h3>
            <p>{product.shortDescription}</p>
            {hasReadyLink ? (
              <AffiliateButton href={product.affiliateUrl} label="Jetzt bei Amazon ansehen" trackingId={product.id} trackingTitle={product.name} />
            ) : (
              <a class="button" href="/reiseprodukte/">Produktübersicht</a>
            )}
          </div>
        </article>
      );
    })}
    <a class="article-sidebar-products__all" href="/reiseprodukte/">Alle Empfehlungen anzeigen →</a>
  </section>

  <section class="article-sidebar-travel-ad">
    <span>Anzeige</span>
    <h2>Urlaub planen?</h2>
    <p>Finde praktische Ideen für familienfreundliche Reisen.</p>
    <ul>
      <li>Angebote vergleichen</li>
      <li>Familienfreundliche Unterkünfte</li>
      <li>Flexibel planen</li>
    </ul>
    <a class="button" href="/urlaub/">Reiseangebote ansehen</a>
  </section>

  <section class="article-sidebar-checklist">
    <h2>Kostenlose Reise-Checkliste für Eltern</h2>
    <p>10 Tipps für entspannteres Reisen mit Baby.</p>
    <a class="button" href="/packlisten/">Packliste ansehen</a>
  </section>
</div>
