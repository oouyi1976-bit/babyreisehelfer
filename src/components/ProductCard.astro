---
import { isAffiliateLinkReady, type Product } from '../data/products';
import ProductVisual from './ProductVisual.astro';

const { product, compact = false } = Astro.props as { product: Product; compact?: boolean };
const hasAffiliateLink = isAffiliateLinkReady(product);
const isAmazonLink = product.affiliateUrl.startsWith('https://www.amazon.de/');
const linkLabel = isAmazonLink ? `${product.title} bei Amazon ansehen` : `${product.title} ansehen`;
---

<article class:list={['product-card', { 'product-card--compact': compact }]}>
  {product.image ? (
    hasAffiliateLink ? (
      <a
        class="product-card__image-shell product-card__image-link"
        href={product.affiliateUrl}
        target="_blank"
        rel="nofollow sponsored noopener noreferrer"
        data-affiliate-link
        data-product-id={product.id}
        data-product-title={product.title}
        aria-label={linkLabel}
      >
        <img
          src={product.image}
          alt={`${product.title} als neutrales Produktbild`}
          width="1200"
          height="675"
          loading="lazy"
          decoding="async"
        />
      </a>
    ) : (
      <div class="product-card__image-shell">
        <img
          src={product.image}
          alt={`${product.title} als neutrales Produktbild`}
          width="1200"
          height="675"
          loading="lazy"
          decoding="async"
        />
      </div>
    )
  ) : hasAffiliateLink ? (
    <a
      class="product-card__visual-link"
      href={product.affiliateUrl}
      target="_blank"
      rel="nofollow sponsored noopener noreferrer"
      data-affiliate-link
      data-product-id={product.id}
      data-product-title={product.title}
      aria-label={linkLabel}
    >
      <ProductVisual product={product} />
    </a>
  ) : (
    <ProductVisual product={product} />
  )}

  <div class="product-card__body">
    <div class="product-card__topline">
      <span>Werbung / Affiliate-Link</span>
    </div>
    <h3>
      {hasAffiliateLink ? (
        <a
          href={product.affiliateUrl}
          target="_blank"
          rel="nofollow sponsored noopener noreferrer"
          data-affiliate-link
          data-product-id={product.id}
          data-product-title={product.title}
          aria-label={linkLabel}
        >
          {product.title}
        </a>
      ) : (
        product.title
      )}
    </h3>
    <p>{product.shortDescription}</p>

    <dl class="product-card__facts">
      <div>
        <dt>Ideal für</dt>
        <dd>{product.idealFor}</dd>
      </div>
      <div>
        <dt>Worauf achten?</dt>
        <dd>{product.whatToLookFor[0]}</dd>
      </div>
    </dl>

    {!compact && (
      <ul class="check-list">
        {product.benefits.slice(0, 3).map((benefit) => (
          <li>{benefit}</li>
        ))}
      </ul>
    )}

    {!compact && <p class="product-card__note">{product.legalNote}</p>}

    {hasAffiliateLink ? (
      <a
        class="button button--affiliate"
        href={product.affiliateUrl}
        target="_blank"
        rel="nofollow sponsored noopener noreferrer"
        data-affiliate-link
        data-product-id={product.id}
        data-product-title={product.title}
      >
        {product.buttonText}
      </a>
    ) : (
      <span class="button button--disabled" aria-disabled="true">
        Produktlink noch nicht eingetragen
      </span>
    )}
  </div>
</article>
