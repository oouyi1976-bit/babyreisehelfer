---
const navItems = [
  { label: 'Packlisten', href: '/packlisten/' },
  { label: 'Babyschlaf', href: '/babyschlaf/' },
  { label: 'Ratgeber', href: '/#ratgeber' },
  { label: 'Produkte', href: '/produkte/' },
  { label: 'Reiseziele', href: '/#reiseziele' },
  { label: 'Über uns', href: '/#ueber-uns' }
];
---

<header class="site-header">
  <div class="container site-header__shell">
    <a class="site-logo" href="/" aria-label="BabyReiseHelfer Startseite">
      <picture class="site-logo__picture">
        <source srcset="/brand/babyreisehelfer-logo.webp" type="image/webp" />
        <img
          src="/brand/babyreisehelfer-logo.png"
          alt="BabyReiseHelfer"
          class="site-logo__image"
          width="936"
          height="163"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </a>

    <nav class="site-nav" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="header-cta" href="/packlisten/">Packliste starten</a>
  </div>
</header>
