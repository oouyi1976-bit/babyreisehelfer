---
const navItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Reiseziele', href: '/urlaub/' },
  { label: 'Packlisten', href: '/packlisten/' },
  { label: 'Unterkünfte', href: '/hotel-mit-baby/' },
  { label: 'Baby unterwegs', href: '/reisen-mit-kind/' },
  { label: 'Über uns', href: '/impressum/' }
];
---

<header class="site-header">
  <div class="container site-header__shell">
    <a class="site-logo" href="/" aria-label="BabyReiseHelfer Startseite">
      <picture class="site-logo__picture">
        <source srcset="/brand/babyreisehelfer-logo.webp" type="image/webp" />
        <img
          src="/brand/babyreisehelfer-logo.png"
          alt="BabyReiseHelfer"
          class="site-logo__image"
          width="936"
          height="163"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <span class="site-logo__tagline">Stressfrei reisen mit Baby</span>
    </a>

    <nav class="site-nav" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="header-search" href="/reiseprodukte/" aria-label="Reiseprodukte entdecken" title="Reiseprodukte entdecken">
      <span aria-hidden="true"></span>
    </a>

    <details class="site-mobile-menu">
      <summary aria-label="Navigation öffnen"><span aria-hidden="true"></span></summary>
      <nav aria-label="Mobile Hauptnavigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </details>
  </div>
</header>
