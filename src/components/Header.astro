---
const navItems = [
  { label: 'Packlisten', href: '/packlisten/' },
  { label: 'Ratgeber', href: '/#ratgeber' },
  { label: 'Produkte', href: '/produkte/' },
  { label: 'Reiseziele', href: '/#reiseziele' },
  { label: 'Über uns', href: '/#ueber-uns' }
];
---

<header class="site-header">
  <div class="container site-header__shell">
    <a class="brand" href="/" aria-label="BabyReiseHelfer Startseite">
      <span class="brand__mark" aria-hidden="true"></span>
      <span>
        <span class="brand__name">BabyReiseHelfer</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="header-cta" href="/packlisten/">Packliste starten</a>
  </div>
</header>
