---
import AffiliateButton from './AffiliateButton.astro';
import { isAmazonAffiliateReady } from '../data/travelProducts';
import type { AmazonArticleCardProduct } from '../data/amazonArticleProducts';

const {
  product,
  label = 'Praktischer Reisebegleiter für Eltern'
} = Astro.props as {
  product: AmazonArticleCardProduct;
  label?: string;
};

const hasReadyLink = isAmazonAffiliateReady(product);
const productImage = product.amazonImageUrl;
const linkAttributes = {
  target: '_blank',
  rel: 'nofollow sponsored noopener noreferrer',
  'data-affiliate-link': true,
  'data-product-id': product.id,
  'data-product-title': product.name
};
---

<section class:list={['inline-affiliate-product', { 'inline-affiliate-product--without-amazon-image': !productImage }]} aria-label={`Produktidee: ${product.name}`}>
  {productImage && (
    <div class="inline-affiliate-product__media">
      {hasReadyLink ? (
        <a href={product.affiliateUrl} aria-label={`${product.name} ansehen`} {...linkAttributes}>
          <img src={productImage} alt={product.name} width="480" height="360" loading="lazy" decoding="async" />
        </a>
      ) : (
        <img src={productImage} alt={product.name} width="480" height="360" loading="lazy" decoding="async" />
      )}
    </div>
  )}
  <div class="inline-affiliate-product__content">
    <p>{label}</p>
    <h3>{hasReadyLink ? <a href={product.affiliateUrl} {...linkAttributes}>{product.name}</a> : product.name}</h3>
    <ul>
      {product.benefits.slice(0, 3).map((benefit) => <li>{benefit}</li>)}
    </ul>
  </div>
  <div class="inline-affiliate-product__action">
    {hasReadyLink ? (
      <AffiliateButton href={product.affiliateUrl} label="Jetzt bei Amazon ansehen" trackingId={product.id} trackingTitle={product.name} />
    ) : (
      <a class="button" href="/reiseprodukte/">Produktübersicht</a>
    )}
  </div>
</section>
