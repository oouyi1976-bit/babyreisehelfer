---
import AffiliateButton from './AffiliateButton.astro';
import { isAmazonAffiliateReady, type TravelProduct } from '../data/travelProducts';

const { product, compact = false } = Astro.props as { product: TravelProduct; compact?: boolean };
const hasReadyLink = isAmazonAffiliateReady(product);
const imageSrc = product.image || '/product-images/reisedokumententasche-familie.webp';
const imageAlt = product.imageAlt || `${product.name} auf BabyReiseHelfer`;
---

<article class:list={['travel-product-card', { 'travel-product-card--compact': compact }]}>
  {hasReadyLink ? (
    <a
      class="travel-product-card__media"
      href={product.affiliateUrl}
      target="_blank"
      rel="nofollow sponsored noopener noreferrer"
      data-affiliate-link
      data-product-id={product.id}
      data-product-title={product.name}
      aria-label={`${product.name} bei Amazon ansehen`}
    >
      <img src={imageSrc} alt={imageAlt} width="900" height="675" loading="lazy" decoding="async" />
    </a>
  ) : (
    <div class="travel-product-card__media travel-product-card__media--disabled">
      <img src={imageSrc} alt={imageAlt} width="900" height="675" loading="lazy" decoding="async" />
    </div>
  )}

  <div class="travel-product-card__body">
    <h3>
      {hasReadyLink ? (
        <a
          href={product.affiliateUrl}
          target="_blank"
          rel="nofollow sponsored noopener noreferrer"
          data-affiliate-link
          data-product-id={product.id}
          data-product-title={product.name}
        >
          {product.name}
        </a>
      ) : (
        product.name
      )}
    </h3>
    <p>{product.shortDescription}</p>

    <dl class="product-card__facts">
      <div>
        <dt>Geeignet für</dt>
        <dd>{product.bestFor}</dd>
      </div>
      <div>
        <dt>Einordnung</dt>
        <dd>{product.priceRange}</dd>
      </div>
    </dl>

    {!compact && (
      <ul class="check-list">
        {product.benefits.slice(0, 3).map((benefit) => (
          <li>{benefit}</li>
        ))}
      </ul>
    )}

    <p class="product-card__note">
      {product.ratingText}. Bitte Herstellerangaben, Maße, Altersempfehlung und Sicherheitshinweise vor dem Kauf prüfen.
    </p>

    <AffiliateButton
      href={product.affiliateUrl}
      label={product.buttonText}
      trackingId={product.id}
      trackingTitle={product.name}
      disabled={!hasReadyLink}
      disabledLabel={product.buttonText}
      fullWidth
    />
  </div>
</article>
