    {visualType === 'night-light' && (
      <g class="pv-scene">
        <path class="pv-fill" d="M124 145 H197 L189 77 C186 55 135 55 132 77 Z"></path>
        <rect class="pv-dark" x="117" y="143" width="88" height="16" rx="8"></rect>
