        <rect class="pv-fill" x="79" y="83" width="154" height="78" rx="18"></rect>
        <path class="pv-line" d="M100 101 H213"></path>
        <rect class="pv-white" x="109" y="57" width="53" height="78" rx="12" transform="rotate(-7 135 96)"></rect>
        <path class="pv-accent" d="M119 80 H151 M119 96 H146 M119 112 H139"></path>
        <rect class="pv-white" x="181" y="69" width="62" height="36" rx="12" transform="rotate(8 212 87)"></rect>
        <path class="pv-line" d="M193 84 H229 M196 94 H221"></path>
