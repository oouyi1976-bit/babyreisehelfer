    {visualType === 'changing-mat' && (
      <g class="pv-scene">
        <rect class="pv-fill" x="85" y="82" width="134" height="72" rx="18"></rect>
        <path class="pv-line" d="M129 83 V154"></path>
        <rect class="pv-white" x="98" y="96" width="46" height="24" rx="10"></rect>
        <rect class="pv-accent" x="156" y="101" width="50" height="16" rx="8"></rect>
        <rect class="pv-fill pv-fill--soft" x="172" y="54" width="60" height="42" rx="13"></rect>
        <path class="pv-line" d="M184 75 H221"></path>
        <circle class="pv-accent" cx="113" cy="136" r="8"></circle>
        <circle class="pv-accent" cx="195" cy="136" r="8"></circle>
      </g>
