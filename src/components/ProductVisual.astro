        <rect class="pv-accent" x="166" y="95" width="28" height="48" rx="10"></rect>
        <circle class="pv-dark" cx="103" cy="158" r="9"></circle>
        <circle class="pv-dark" cx="217" cy="158" r="9"></circle>
