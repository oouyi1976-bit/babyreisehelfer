---
import type { Product } from '../data/products';

const { product } = Astro.props as { product: Product };

const iconToVisual: Record<string, string> = {
  sunshade: 'stroller-sunshade',
  mat: 'changing-mat',
  pouch: 'changing-mat',
  wipe: 'changing-mat',
  night: 'night-light',
  light: 'night-light',
  tent: 'beach-tent',
  shade: 'beach-tent',
  hat: 'beach-tent',
  glasses: 'beach-tent',
  ear: 'baby-earmuffs',
  cross: 'first-aid-box',
  fan: 'stroller-fan',
  bottle: 'bottle-warmer',
  bed: 'travel-crib',
  thermos: 'thermos-bottle',
  cube: 'packing-cubes',
  bag: 'packing-cubes',
  drop: 'packing-cubes',
  toiletry: 'packing-cubes',
  bath: 'travel-crib',
  document: 'document-organizer',
  net: 'mosquito-net',
  organizer: 'stroller-organizer',
  rain: 'rain-cover',
  sleep: 'sleep-guide'
};

const visualType = product.imageType && product.imageType !== 'css-icon'
  ? product.imageType
  : iconToVisual[product.icon] ?? 'fallback';
---

<div class={`product-visual product-visual--${visualType}`} role="img" aria-label={`${product.title} Illustration`}>
  <svg viewBox="0 0 320 190" aria-hidden="true" focusable="false">
    <rect class="pv-bg" x="0" y="0" width="320" height="190" rx="0"></rect>
    <circle class="pv-sun" cx="258" cy="43" r="25"></circle>
    <path class="pv-ground" d="M36 151 C74 135 104 159 144 148 C189 136 224 148 284 137 L284 177 L36 177 Z"></path>

    {visualType === 'stroller-sunshade' && (
      <g class="pv-scene">
        <path class="pv-accent" d="M92 82 C111 52 161 47 192 77 L185 96 C159 83 126 84 100 100 Z"></path>
        <path class="pv-line" d="M103 99 C128 83 158 83 184 97"></path>
        <path class="pv-line" d="M124 91 L116 131"></path>
        <path class="pv-line" d="M166 91 L174 131"></path>
        <path class="pv-fill pv-fill--soft" d="M101 129 H203 C197 151 181 161 151 161 H127 C113 161 102 148 101 129 Z"></path>
        <path class="pv-line" d="M204 129 C225 124 239 114 247 96"></path>
        <circle class="pv-dark" cx="126" cy="163" r="12"></circle>
