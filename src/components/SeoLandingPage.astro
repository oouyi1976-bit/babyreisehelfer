---
import Layout from '../layouts/Layout.astro';
import AffiliateDisclosure from './AffiliateDisclosure.astro';
import CTABox from './CTABox.astro';
import ProductGrid from './ProductGrid.astro';
import { getTravelProductsByIds } from '../data/travelProducts';
import type { SeoLandingPage } from '../data/seoLandingPages';

const { page } = Astro.props as { page: SeoLandingPage };
const products = getTravelProductsByIds(page.productIds);
const pageUrl = new URL(`/${page.slug}/`, Astro.site).href;
const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: page.title,
  description: page.description,
  url: pageUrl,
  inLanguage: 'de-DE'
};
---

<Layout title={page.title} description={page.description} jsonLd={pageSchema}>
  <section class="travel-page-hero seo-landing-hero">
    <div class="container travel-page-hero__grid">
      <div class="travel-page-hero__content">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.h1}</h1>
        <p>{page.intro}</p>
        <div class="hero__actions">
          <a class="button" href="#checkliste">Checkliste lesen</a>
          <a class="button button--secondary" href="#produktideen">Produktideen ansehen</a>
        </div>
      </div>
      <div class="travel-page-hero__image">
        <img src={page.heroImage} alt={`${page.h1} auf BabyReiseHelfer`} loading="eager" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section" id="checkliste">
    <div class="container">
      <div class="section__header">
        <p class="eyebrow">Praktische Checkliste</p>
        <h2>Was du vor der Reise sortieren solltest</h2>
      </div>
      <div class="travel-info-grid">
        {page.checklist.map((group) => (
          <article class="travel-info-card">
            <p class="eyebrow">Checkliste</p>
            <h2>{group.heading}</h2>
            <p>{group.text}</p>
            <ul class="check-list">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft" id="produktideen">
    <div class="container">
      <div class="section__header section__header--split">
        <div>
          <p class="eyebrow">Produktideen</p>
          <h2>Passende Helfer für diese Checkliste</h2>
        </div>
        <p>
          Neutrale Produktideen ohne Amazon-Preise, ohne Sternebewertungen und ohne erfundene Testsieger.
        </p>
      </div>
      <AffiliateDisclosure compact />
      <ProductGrid products={products} compact />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <p class="eyebrow">Weiterlesen</p>
        <h2>Verwandte Babyreise-Ratgeber</h2>
      </div>
      <div class="travel-home-grid travel-home-grid--compact">
        {page.relatedLinks.map((link) => (
          <a class="travel-home-card" href={link.href}>
            <span>{link.title}</span>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="container section">
    <CTABox
      title="Weiter planen ohne Überpacken"
      text="Nutze den passenden Haupt-Ratgeber, wenn du die Checkliste mit weiteren Tipps vertiefen möchtest."
      href={page.ctaHref}
      buttonText={page.ctaText}
    />
  </div>
</Layout>
