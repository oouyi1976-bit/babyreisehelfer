---
import { isAffiliateLinkReady, type Product } from '../data/products';

const {
  product,
  href,
  label,
  fullWidth = false,
  trackingId,
  trackingTitle,
  disabled = false,
  disabledLabel = 'Link noch nicht verfügbar'
} = Astro.props as {
  product?: Product;
  href?: string;
  label?: string;
  fullWidth?: boolean;
  trackingId?: string;
  trackingTitle?: string;
  disabled?: boolean;
  disabledLabel?: string;
};

const link = product?.affiliateUrl ?? href ?? '';
const text = label ?? product?.buttonText ?? 'Ansehen';
const isPlaceholder = link === 'AMAZON_AFFILIATE_LINK_HIER_EINFUEGEN' || link.includes('AMAZON_AFFILIATE');
const isReady = product ? isAffiliateLinkReady(product) : Boolean(href) && !isPlaceholder && !disabled;
---

{isReady ? (
  <a
    class:list={['button', 'button--affiliate', 'affiliate-button', { 'affiliate-button--full': fullWidth }]}
    href={link}
    target="_blank"
    rel="nofollow sponsored noopener noreferrer"
    data-affiliate-link
    data-product-id={product?.id ?? trackingId ?? 'affiliate-link'}
    data-product-title={product?.title ?? trackingTitle ?? text}
  >
    {text}
  </a>
) : (
  <span class:list={['button', 'button--disabled', 'affiliate-button', { 'affiliate-button--full': fullWidth }]} aria-disabled="true">
    {disabledLabel}
  </span>
)}
